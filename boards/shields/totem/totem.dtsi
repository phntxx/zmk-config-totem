#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &totem_physical_layout;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
        map = <
                RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
                RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
        RC(3,0) RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(3,9)
                                RC(3,2) RC(3,3) RC(3,4)    RC(3,5) RC(3,6) RC(3,7)         
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row"; 
        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };
    
     totem_physical_layout: totem_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "TOTEM Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        
        keys
            // Row 0: Q W E R T | Y U I O P
            = <&key_physical_attrs 100 100   266   480   0   0   0>  // Q
            , <&key_physical_attrs 100 100   387   387   0   0   0>  // W
            , <&key_physical_attrs 100 100   512   326   0   0   0>  // E
            , <&key_physical_attrs 100 100   620   375   0   0   0>  // R
            , <&key_physical_attrs 100 100   728   392   0   0   0>  // T
            , <&key_physical_attrs 100 100  1073   392   0   0   0>  // Y (using P's coord)
            , <&key_physical_attrs 100 100  1181   375   0   0   0>  // U (using O's coord)
            , <&key_physical_attrs 100 100  1289   326   0   0   0>  // I (stays)
            , <&key_physical_attrs 100 100  1412   387   0   0   0>  // O (using U's coord)
            , <&key_physical_attrs 100 100  1533   480   0   0   0>  // P (using Y's coord)
            
            // Row 1: A S D F G | H J K L ;
            , <&key_physical_attrs 100 100   284   581   0   0   0>  // A
            , <&key_physical_attrs 100 100   395   489   0   0   0>  // S
            , <&key_physical_attrs 100 100   512   428   0   0   0>  // D
            , <&key_physical_attrs 100 100   620   477   0   0   0>  // F
            , <&key_physical_attrs 100 100   728   494   0   0   0>  // G
            , <&key_physical_attrs 100 100  1073   495   0   0   0>  // H (using ;'s coord)
            , <&key_physical_attrs 100 100  1181   477   0   0   0>  // J (using L's coord)
            , <&key_physical_attrs 100 100  1289   428   0   0   0>  // K (stays)
            , <&key_physical_attrs 100 100  1404   489   0   0   0>  // L (using J's coord)
            , <&key_physical_attrs 100 100  1515   581   0   0   0>  // ; (using H's coord)
            
            // Row 2: [ Z X C V B | N M , . / ]
            , <&key_physical_attrs 100 100   188   654   0   0   0>  // [
            , <&key_physical_attrs 100 100   302   681   0   0   0>  // Z
            , <&key_physical_attrs 100 100   402   590   0   0   0>  // X
            , <&key_physical_attrs 100 100   512   530   0   0   0>  // C
            , <&key_physical_attrs 100 100   620   579   0   0   0>  // V
            , <&key_physical_attrs 100 100   728   596   0   0   0>  // B
            , <&key_physical_attrs 100 100  1073   597   0   0   0>  // N (using ]'s coord)
            , <&key_physical_attrs 100 100  1181   579   0   0   0>  // M (using /'s coord)
            , <&key_physical_attrs 100 100  1289   530   0   0   0>  // , (using .'s coord)
            , <&key_physical_attrs 100 100  1398   590   0   0   0>  // . (using ,'s coord)
            , <&key_physical_attrs 100 100  1499   681   0   0   0>  // / (using M's coord)
            , <&key_physical_attrs 100 100  1613   654   0   0   0>  // ] (using N's coord)
            
            // Row 3: ESC BSPC TAB | ENT SPC LSHFT
            , <&key_physical_attrs 100 100   588   704   0   0   0>  // ESC
            , <&key_physical_attrs 100 100   708   720   0   0   0>  // BSPC
            , <&key_physical_attrs 100 100   819   767   0   0   0>  // TAB
            , <&key_physical_attrs 100 100   981   767   0   0   0>  // ENT (using LSHFT's coord)
            , <&key_physical_attrs 100 100  1092   720   0   0   0>  // SPC (stays)
            , <&key_physical_attrs 100 100  1211   704   0   0   0>  // LSHFT (using ENT's coord)
            ;
    };


